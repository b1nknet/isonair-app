{
  "name": "isonair-app",
  "version": "1.3.1",
  "description": "Chzzk stream info widget",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "icon": "electron scripts/render-icon.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "net.b1nk.isonair",
    "productName": "isonair",
    "artifactName": "isonair-${version}-${arch}.${ext}",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "b1nknet",
        "repo": "isonair-app"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "identity": null,
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "isonair-Setup-${version}.${ext}"
    }
  }
}
