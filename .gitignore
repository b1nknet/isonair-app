# Dependencies
node_modules/

# Build output
dist/
out/
# build/ is electron-builder's buildResources dir; ignore its contents but keep
# the committed app icon (generated from src/img/icon.svg via `npm run icon`).
build/*
!build/icon.png

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Electron-builder cache
.cache/

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Env
.env
.env.local
